.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.connection-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.connection-status {
  display: flex;
  align-items: center;
}

.connect-btn {
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 15rpx 30rpx;
  font-size: 26rpx;
}

.connect-btn.disconnect {
  background: linear-gradient(135deg, #ea4335 0%, #d3392e 100%);
}

.connect-btn[disabled] {
  opacity: 0.6;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-dot.connected {
  background-color: #34a853;
  animation: pulse 2s infinite;
}

.status-dot.disconnected {
  background-color: #ea4335;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 26rpx;
  color: #666666;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #1a73e8;
}

.sensor-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sensor-item {
  width: calc(33.33% - 14rpx);
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sensor-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sensor-icon.temperature {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
}

.sensor-icon.humidity {
  background: linear-gradient(135deg, #4ecdc4 0%, #44a3a0 100%);
}

.sensor-icon.light {
  background: linear-gradient(135deg, #ffe66d 0%, #ffd93d 100%);
}

.sensor-icon.speed {
  background: linear-gradient(135deg, #95e1d3 0%, #7dd3c5 100%);
}

.sensor-icon.water {
  background: linear-gradient(135deg, #667eea 0%, #5a6fd6 100%);
}

.sensor-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sensor-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.sensor-name {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}

.device-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.device-item {
  width: calc(50% - 10rpx);
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.device-icon.gate {
  background: linear-gradient(135deg, #667eea 0%, #5a6fd6 100%);
}

.device-icon.light {
  background: linear-gradient(135deg, #ffe66d 0%, #ffd93d 100%);
}

.device-icon.access {
  background: linear-gradient(135deg, #95e1d3 0%, #7dd3c5 100%);
}

.device-icon.fan {
  background: linear-gradient(135deg, #4ecdc4 0%, #44a3a0 100%);
}

.device-name {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 15rpx;
}

.device-switch {
  transform: scale(0.8);
}

.status-list {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 10rpx 0;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 25rpx;
  border-bottom: 1rpx solid #e8eaed;
}

.status-row:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: #333333;
}

.status-value {
  font-size: 28rpx;
}

.status-active {
  color: #34a853;
}

.status-inactive {
  color: #999999;
}

.device-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  z-index: 1000;
}

.device-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.device-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #e8eaed;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999999;
}

.scan-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.scan-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1a73e8;
  margin-right: 15rpx;
  animation: scan-pulse 1.5s infinite;
}

@keyframes scan-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.scan-info text {
  font-size: 26rpx;
  color: #666666;
}

.device-list {
  max-height: 50vh;
}

.device-item-list {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.device-icon-bluetooth {
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.device-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.device-name-list {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.device-id {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}

.device-rssi {
  font-size: 24rpx;
  color: #666666;
}

.empty-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999999;
}

.nav-buttons {
  padding: 20rpx;
  margin-top: 20rpx;
}

.nav-btn {
  width: 100%;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.nav-btn:active {
  opacity: 0.8;
}