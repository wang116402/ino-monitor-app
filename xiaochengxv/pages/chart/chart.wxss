.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #1a73e8;
}

.chart-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f7fa;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab-item.active {
  background: #1a73e8;
  color: #ffffff;
}

.tab-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.tab-dot.temperature { background: #ff6b6b; }
.tab-dot.humidity { background: #4ecdc4; }
.tab-dot.light { background: #ffe66d; }
.tab-dot.speed { background: #95e1d3; }
.tab-dot.water { background: #667eea; }

.tab-item.active .tab-dot {
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

.chart-container {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.chart-canvas {
  width: 100%;
  height: 350rpx;
}

.chart-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-row {
  width: calc(50% - 10rpx);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: #f9fafb;
  border-radius: 10rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a73e8;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.overview-item {
  width: calc(33.33% - 10rpx);
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 32rpx;
  font-weight: 600;
}

.overview-value.temp { color: #ff6b6b; }
.overview-value.hum { color: #4ecdc4; }
.overview-value.light { color: #ffe66d; }
.overview-value.speed { color: #95e1d3; }
.overview-value.water { color: #667eea; }

.overview-unit {
  font-size: 20rpx;
  color: #999999;
  margin-left: 5rpx;
}

.overview-name {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
}